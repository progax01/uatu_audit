  "steps": [
    {
      "id": "detect-framework",
      "name": "Detect Framework",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": [],
      "provides": ["detectedFramework", "detectedLanguage"],
      "requires": [],
      "config": {
        "function": "detectFramework"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "validate-structure",
      "name": "Validate Project Structure",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["detect-framework"],
      "provides": ["projectValid", "sourceDirectories"],
      "requires": ["detectedFramework"],
      "config": {
        "function": "validateStructure"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "parse-move-toml",
      "name": "Parse Move.toml",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["validate-structure"],
      "provides": ["moveConfig", "packageName", "dependencies"],
      "requires": ["projectValid"],
      "config": {
        "function": "parseMoveToml"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "enumerate-modules",
      "name": "Enumerate Modules",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["validate-structure"],
      "provides": ["moduleFiles", "mainModules", "testModules", "scriptModules"],
      "requires": ["sourceDirectories"],
      "config": {
        "function": "enumerateModules"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "count-sloc",
      "name": "Count SLOC",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["enumerate-modules"],
      "provides": ["sloc", "complexity"],
      "requires": ["moduleFiles"],
      "config": {
        "function": "countSloc"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-dependencies",
      "name": "Analyze Dependencies",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["parse-move-toml"],
      "provides": ["dependencyGraph", "frameworkVersion", "externalDependencies"],
      "requires": ["dependencies"],
      "config": {
        "function": "analyzeDependencies"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-aptos-compile",
      "name": "Run Aptos Compile",
      "category": "compilation",
      "executor": "tool",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["parse-move-toml"],
      "provides": ["compilationSuccess", "compilationArtifacts", "compilationWarnings"],
      "requires": ["moveConfig"],
      "config": {
        "tool": "aptos",
        "command": "move compile",
        "args": ["--save-metadata"],
        "timeout": 180000
      },
      "progressWeight": 5,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 1
    },
    {
      "id": "parse-compilation",
      "name": "Parse Compilation Results",
      "category": "compilation",
