{
  "id": "move-aptos",
  "name": "Move Aptos Audit SOP",
  "version": "1.0.0",
  "framework": "aptos-move",
  "language": "move",
  "description": "Standard Operating Procedure for auditing Move smart contracts on Aptos blockchain",

  "depths": {
    "quick": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-move-toml",
        "enumerate-modules",
        "count-sloc",
        "run-aptos-compile",
        "run-move-prover-quick",
        "parse-prover",
        "merge-tool-findings",
        "ai-quick-review",
        "calculate-score",
        "generate-report"
      ],
      "estimatedDurationMinutes": 8,
      "parallelization": "none"
    },
    "standard": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-move-toml",
        "enumerate-modules",
        "count-sloc",
        "analyze-dependencies",
        "run-aptos-compile",
        "parse-compilation",
        "analyze-module-structure",
        "map-resource-types",
        "analyze-entry-functions",
        "identify-acquires",
        "run-move-prover",
        "parse-prover",
        "check-tests-exist",
        "run-aptos-test",
        "parse-test-results",
        "merge-tool-findings",
        "ai-capability-analysis",
        "ai-resource-safety",
        "ai-access-control",
        "ai-signer-checks",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 25,
      "parallelization": "low"
    },
    "deep": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-move-toml",
        "enumerate-modules",
        "count-sloc",
        "analyze-dependencies",
        "run-aptos-compile",
        "parse-compilation",
        "analyze-module-structure",
        "map-resource-types",
        "analyze-entry-functions",
        "identify-acquires",
        "analyze-global-storage",
        "run-move-prover-deep",
        "parse-prover",
        "run-move-mutator",
        "parse-mutator",
        "check-tests-exist",
        "run-aptos-test",
        "parse-test-results",
        "run-coverage",
        "parse-coverage",
        "merge-tool-findings",
        "ai-capability-analysis",
        "ai-resource-safety",
        "ai-access-control",
        "ai-signer-checks",
        "ai-abort-conditions",
        "ai-type-safety",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 45,
      "parallelization": "high"
