{
  "id": "anchor-solana",
  "name": "Anchor Solana Audit SOP",
  "version": "1.0.0",
  "framework": "anchor",
  "language": "rust",
  "description": "Standard Operating Procedure for auditing Solana programs using Anchor framework",

  "depths": {
    "quick": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-anchor-toml",
        "enumerate-programs",
        "count-sloc",
        "run-anchor-build",
        "run-cargo-clippy",
        "parse-clippy",
        "merge-tool-findings",
        "ai-quick-review",
        "calculate-score",
        "generate-report"
      ],
      "estimatedDurationMinutes": 10,
      "parallelization": "none"
    },
    "standard": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-anchor-toml",
        "enumerate-programs",
        "count-sloc",
        "analyze-cargo-dependencies",
        "run-anchor-build",
        "parse-compilation",
        "analyze-program-structure",
        "map-account-structures",
        "analyze-instructions",
        "identify-cpis",
        "run-cargo-clippy",
        "parse-clippy",
        "run-soteria",
        "parse-soteria",
        "check-tests-exist",
        "run-anchor-test",
        "parse-test-results",
        "merge-tool-findings",
        "ai-account-validation",
        "ai-signer-checks",
        "ai-pda-security",
        "ai-cpi-security",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 30,
      "parallelization": "low"
    },
    "deep": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-anchor-toml",
        "enumerate-programs",
        "count-sloc",
        "analyze-cargo-dependencies",
        "run-anchor-build",
        "parse-compilation",
        "analyze-program-structure",
        "map-account-structures",
        "analyze-instructions",
        "identify-cpis",
        "analyze-state-mutations",
        "run-cargo-clippy",
        "parse-clippy",
        "run-cargo-audit",
        "parse-cargo-audit",
        "run-soteria",
        "parse-soteria",
        "run-xray",
        "parse-xray",
        "check-tests-exist",
        "run-anchor-test",
        "parse-test-results",
        "merge-tool-findings",
        "ai-account-validation",
        "ai-signer-checks",
        "ai-pda-security",
        "ai-cpi-security",
        "ai-arithmetic-overflow",
        "ai-authority-checks",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 50,
      "parallelization": "high"
    }
  },

  "steps": [
    {
      "id": "detect-framework",
      "name": "Detect Framework",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": [],
      "provides": ["detectedFramework", "detectedLanguage"],
      "requires": [],
      "config": {
        "function": "detectFramework"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "validate-structure",
      "name": "Validate Project Structure",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["detect-framework"],
      "provides": ["projectValid", "sourceDirectories"],
      "requires": ["detectedFramework"],
      "config": {
        "function": "validateStructure"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "parse-anchor-toml",
      "name": "Parse Anchor.toml",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["validate-structure"],
      "provides": ["anchorConfig", "programIds", "clusters"],
      "requires": ["projectValid"],
      "config": {
        "function": "parseAnchorToml"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "enumerate-programs",
      "name": "Enumerate Programs",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["validate-structure"],
      "provides": ["programFiles", "mainPrograms", "testPrograms", "libraryModules"],
      "requires": ["sourceDirectories"],
      "config": {
        "function": "enumeratePrograms"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "count-sloc",
      "name": "Count SLOC",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["enumerate-programs"],
      "provides": ["sloc", "complexity"],
      "requires": ["programFiles"],
      "config": {
        "function": "countSloc"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-cargo-dependencies",
      "name": "Analyze Cargo Dependencies",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["validate-structure"],
      "provides": ["cargoDependencies", "anchorVersion", "solanaVersion"],
      "requires": ["projectValid"],
      "config": {
        "function": "analyzeCargoDependencies"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-anchor-build",
      "name": "Run Anchor Build",
      "category": "compilation",
      "executor": "tool",
      "estimatedDurationSeconds": 60,
      "dependsOn": ["parse-anchor-toml"],
      "provides": ["compilationSuccess", "compilationArtifacts", "compilationWarnings"],
      "requires": ["anchorConfig"],
      "config": {
        "tool": "anchor",
        "command": "build",
        "args": [],
        "timeout": 300000
      },
      "progressWeight": 6,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 1
    },
    {
      "id": "parse-compilation",
      "name": "Parse Compilation Results",
      "category": "compilation",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-anchor-build"],
      "provides": ["parsedArtifacts", "programIdl"],
      "requires": ["compilationArtifacts"],
      "config": {
        "function": "parseAnchorCompilation"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-program-structure",
      "name": "Analyze Program Structure",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["enumerate-programs"],
      "provides": ["programStructure", "moduleGraph"],
      "requires": ["programFiles"],
      "config": {
        "function": "analyzeProgramStructure"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "map-account-structures",
      "name": "Map Account Structures",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 20,
      "dependsOn": ["analyze-program-structure"],
      "provides": ["accountStructures", "accountConstraints", "pdaSeeds"],
      "requires": ["programStructure"],
      "config": {
        "function": "mapAccountStructures"
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-instructions",
      "name": "Analyze Instructions",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["analyze-program-structure"],
      "provides": ["instructions", "instructionHandlers", "accessControl"],
      "requires": ["programStructure"],
      "config": {
        "function": "analyzeInstructions"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "identify-cpis",
      "name": "Identify Cross-Program Invocations",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 20,
      "dependsOn": ["analyze-instructions"],
      "provides": ["cpiCalls", "invokedPrograms", "cpiContexts"],
      "requires": ["instructions"],
      "config": {
        "function": "identifyCpis"
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-state-mutations",
      "name": "Analyze State Mutations",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["map-account-structures", "analyze-instructions"],
      "provides": ["stateMutations", "dataFlows"],
      "requires": ["accountStructures", "instructions"],
      "config": {
        "function": "analyzeStateMutations"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-cargo-clippy",
      "name": "Run Cargo Clippy",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["run-anchor-build"],
      "provides": ["clippyOutput", "clippyFindings"],
      "requires": ["compilationSuccess"],
      "config": {
        "tool": "cargo-clippy",
        "args": ["--", "-W", "clippy::all", "-W", "clippy::pedantic", "--message-format=json"],
        "timeout": 120000,
        "optional": false
      },
      "progressWeight": 4,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "parse-clippy",
      "name": "Parse Clippy Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-cargo-clippy"],
      "provides": ["parsedClippyFindings"],
      "requires": ["clippyOutput"],
      "config": {
        "function": "parseClippy"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-cargo-audit",
      "name": "Run Cargo Audit",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 20,
      "dependsOn": ["analyze-cargo-dependencies"],
      "provides": ["cargoAuditOutput", "vulnerableDependencies"],
      "requires": ["cargoDependencies"],
      "config": {
        "tool": "cargo-audit",
        "args": ["--json"],
        "timeout": 60000,
        "optional": true
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-cargo-audit",
      "name": "Parse Cargo Audit Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-cargo-audit"],
      "provides": ["parsedCargoAuditFindings"],
      "requires": ["cargoAuditOutput"],
      "config": {
        "function": "parseCargoAudit"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-soteria",
      "name": "Run Soteria Scanner",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 60,
      "dependsOn": ["run-anchor-build"],
      "provides": ["soteriaOutput", "soteriaFindings"],
      "requires": ["compilationSuccess"],
      "config": {
        "tool": "soteria",
        "args": ["-analyzeAll"],
        "timeout": 180000,
        "optional": true
      },
      "progressWeight": 6,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-soteria",
      "name": "Parse Soteria Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-soteria"],
      "provides": ["parsedSoteriaFindings"],
      "requires": ["soteriaOutput"],
      "config": {
        "function": "parseSoteria"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-xray",
      "name": "Run Sec3 X-ray",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["run-anchor-build"],
      "provides": ["xrayOutput", "xrayFindings"],
      "requires": ["compilationSuccess"],
      "config": {
        "tool": "xray",
        "args": ["scan", "--format", "json"],
        "timeout": 180000,
        "optional": true
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-xray",
      "name": "Parse X-ray Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-xray"],
      "provides": ["parsedXrayFindings"],
      "requires": ["xrayOutput"],
      "config": {
        "function": "parseXray"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "check-tests-exist",
      "name": "Check for Tests",
      "category": "testing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["validate-structure"],
      "provides": ["testsExist", "testFiles", "testFramework"],
      "requires": ["sourceDirectories"],
      "config": {
        "function": "checkTestsExist"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-anchor-test",
      "name": "Run Anchor Tests",
      "category": "testing",
      "executor": "tool",
      "estimatedDurationSeconds": 90,
      "dependsOn": ["run-anchor-build", "check-tests-exist"],
      "provides": ["testResults", "testsPassed", "testsFailed"],
      "requires": ["compilationSuccess", "testsExist"],
      "config": {
        "tool": "anchor",
        "command": "test",
        "args": ["--skip-local-validator"],
        "timeout": 300000,
        "optional": true
      },
      "progressWeight": 7,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-test-results",
      "name": "Parse Test Results",
      "category": "testing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-anchor-test"],
      "provides": ["parsedTestResults"],
      "requires": ["testResults"],
      "config": {
        "function": "parseTestResults"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "merge-tool-findings",
      "name": "Merge Tool Findings",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["parse-clippy", "parse-soteria", "parse-xray", "parse-cargo-audit"],
      "provides": ["mergedFindings", "findingsByCategory"],
      "requires": [],
      "config": {
        "function": "mergeToolFindings"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "ai-quick-review",
      "name": "AI Quick Review",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["merge-tool-findings", "enumerate-programs"],
      "provides": ["quickReviewFindings"],
      "requires": ["mergedFindings", "mainPrograms"],
      "config": {
        "prompt": "quick-review-solana",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-account-validation",
      "name": "AI Account Validation Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["map-account-structures", "analyze-instructions"],
