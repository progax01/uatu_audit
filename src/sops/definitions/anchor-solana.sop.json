      "config": {
        "function": "calculateSeverity"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "calculate-score",
      "name": "Calculate Audit Score",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["calculate-severity"],
      "provides": ["auditScore", "scoreBreakdown"],
      "requires": ["severityRankedFindings"],
      "config": {
        "function": "calculateScore"
      },
      "progressWeight": 1,
