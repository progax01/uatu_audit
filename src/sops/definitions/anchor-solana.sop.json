      "requires": ["accountStructures", "instructions"],
      "config": {
        "prompt": "check-account-validation",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-signer-checks",
      "name": "AI Signer Check Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
