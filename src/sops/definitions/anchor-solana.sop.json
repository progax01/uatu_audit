      "retryCount": 1
    },
    {
      "id": "ai-pda-security",
      "name": "AI PDA Security Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["map-account-structures"],
      "provides": ["pdaSecurityFindings", "pdaVulnerabilities"],
      "requires": ["accountStructures", "pdaSeeds"],
      "config": {
        "prompt": "check-pda-security",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-cpi-security",
      "name": "AI CPI Security Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["identify-cpis"],
      "provides": ["cpiSecurityFindings", "cpiVulnerabilities"],
      "requires": ["cpiCalls", "invokedPrograms"],
      "config": {
        "prompt": "check-cpi-security",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
