{
  "id": "ink-substrate",
  "name": "ink! Substrate Audit SOP",
  "version": "1.0.0",
  "framework": "ink",
  "language": "rust",
  "description": "Standard Operating Procedure for auditing ink! smart contracts on Substrate/Polkadot",

  "depths": {
    "quick": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-cargo-toml",
        "enumerate-contracts",
        "count-sloc",
        "run-cargo-contract-build",
        "run-cargo-clippy",
        "parse-clippy",
        "merge-tool-findings",
        "ai-quick-review",
        "calculate-score",
        "generate-report"
      ],
      "estimatedDurationMinutes": 10,
      "parallelization": "none"
    },
    "standard": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-cargo-toml",
        "enumerate-contracts",
        "count-sloc",
        "analyze-cargo-dependencies",
        "run-cargo-contract-build",
        "parse-compilation",
        "analyze-contract-structure",
        "map-storage-layout",
        "analyze-messages",
        "identify-cross-contract-calls",
        "run-cargo-clippy",
        "parse-clippy",
        "run-cargo-audit",
        "parse-cargo-audit",
        "check-tests-exist",
        "run-cargo-test",
        "parse-test-results",
        "merge-tool-findings",
        "ai-storage-analysis",
        "ai-reentrancy",
        "ai-access-control",
        "ai-arithmetic",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 28,
      "parallelization": "low"
    },
    "deep": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "parse-cargo-toml",
        "enumerate-contracts",
        "count-sloc",
        "analyze-cargo-dependencies",
        "run-cargo-contract-build",
        "parse-compilation",
        "analyze-contract-structure",
        "map-storage-layout",
        "analyze-messages",
        "identify-cross-contract-calls",
        "analyze-trait-implementations",
        "run-cargo-clippy",
        "parse-clippy",
        "run-cargo-audit",
        "parse-cargo-audit",
        "run-dylint",
        "parse-dylint",
        "check-tests-exist",
        "run-cargo-test",
        "parse-test-results",
        "run-coverage",
        "parse-coverage",
        "merge-tool-findings",
        "ai-storage-analysis",
        "ai-reentrancy",
        "ai-access-control",
        "ai-arithmetic",
        "ai-cross-contract",
        "ai-upgrade-safety",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 45,
      "parallelization": "high"
    }
  },

  "steps": [
    {
      "id": "detect-framework",
      "name": "Detect Framework",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": [],
      "provides": ["detectedFramework", "detectedLanguage"],
      "requires": [],
      "config": {
        "function": "detectFramework"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "validate-structure",
      "name": "Validate Project Structure",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["detect-framework"],
      "provides": ["projectValid", "sourceDirectories"],
      "requires": ["detectedFramework"],
      "config": {
        "function": "validateStructure"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "parse-cargo-toml",
      "name": "Parse Cargo.toml",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["validate-structure"],
      "provides": ["cargoConfig", "inkVersion", "dependencies"],
      "requires": ["projectValid"],
      "config": {
        "function": "parseCargoToml"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "enumerate-contracts",
      "name": "Enumerate Contracts",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["validate-structure"],
      "provides": ["contractFiles", "mainContracts", "testFiles", "libModules"],
      "requires": ["sourceDirectories"],
      "config": {
        "function": "enumerateInkContracts"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "count-sloc",
      "name": "Count SLOC",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["sloc", "complexity"],
      "requires": ["contractFiles"],
      "config": {
        "function": "countSloc"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-cargo-dependencies",
      "name": "Analyze Cargo Dependencies",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["parse-cargo-toml"],
      "provides": ["dependencyGraph", "inkVersion", "substrateVersion"],
      "requires": ["dependencies"],
      "config": {
        "function": "analyzeCargoDependencies"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-cargo-contract-build",
      "name": "Run Cargo Contract Build",
      "category": "compilation",
      "executor": "tool",
      "estimatedDurationSeconds": 60,
      "dependsOn": ["parse-cargo-toml"],
      "provides": ["compilationSuccess", "compilationArtifacts", "wasmArtifact", "metadataJson"],
      "requires": ["cargoConfig"],
      "config": {
        "tool": "cargo-contract",
        "command": "build",
        "args": ["--release"],
        "timeout": 300000
      },
      "progressWeight": 6,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 1
    },
    {
      "id": "parse-compilation",
      "name": "Parse Compilation Results",
      "category": "compilation",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-cargo-contract-build"],
      "provides": ["parsedArtifacts", "contractMetadata", "abiSpec"],
      "requires": ["compilationArtifacts"],
      "config": {
        "function": "parseInkCompilation"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-contract-structure",
      "name": "Analyze Contract Structure",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["contractStructure", "moduleGraph", "constructors"],
      "requires": ["contractFiles"],
      "config": {
        "function": "analyzeInkContractStructure"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "map-storage-layout",
      "name": "Map Storage Layout",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 20,
      "dependsOn": ["analyze-contract-structure"],
      "provides": ["storageLayout", "storageItems", "lazyFields", "mappings"],
      "requires": ["contractStructure"],
      "config": {
        "function": "mapInkStorageLayout"
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-messages",
      "name": "Analyze Messages",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["analyze-contract-structure"],
      "provides": ["messages", "publicMessages", "payableMessages", "selectors"],
      "requires": ["contractStructure"],
      "config": {
        "function": "analyzeInkMessages"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "identify-cross-contract-calls",
      "name": "Identify Cross-Contract Calls",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["analyze-messages"],
      "provides": ["crossContractCalls", "callBuilderUsage", "delegateCalls"],
      "requires": ["messages"],
      "config": {
        "function": "identifyCrossContractCalls"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-trait-implementations",
      "name": "Analyze Trait Implementations",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["analyze-contract-structure"],
      "provides": ["traitImpls", "psp22Impl", "psp34Impl", "openbrushUsage"],
      "requires": ["contractStructure"],
      "config": {
        "function": "analyzeTraitImplementations"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-cargo-clippy",
      "name": "Run Cargo Clippy",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["run-cargo-contract-build"],
      "provides": ["clippyOutput", "clippyFindings"],
      "requires": ["compilationSuccess"],
      "config": {
        "tool": "cargo-clippy",
        "args": ["--", "-W", "clippy::all", "--message-format=json"],
        "timeout": 120000,
        "optional": false
      },
      "progressWeight": 4,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "parse-clippy",
      "name": "Parse Clippy Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-cargo-clippy"],
      "provides": ["parsedClippyFindings"],
      "requires": ["clippyOutput"],
      "config": {
        "function": "parseClippy"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-cargo-audit",
      "name": "Run Cargo Audit",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 20,
      "dependsOn": ["analyze-cargo-dependencies"],
      "provides": ["cargoAuditOutput", "vulnerableDependencies"],
      "requires": ["dependencyGraph"],
      "config": {
        "tool": "cargo-audit",
        "args": ["--json"],
        "timeout": 60000,
        "optional": true
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-cargo-audit",
      "name": "Parse Cargo Audit Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-cargo-audit"],
      "provides": ["parsedCargoAuditFindings"],
      "requires": ["cargoAuditOutput"],
      "config": {
        "function": "parseCargoAudit"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-dylint",
      "name": "Run Dylint Lints",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["run-cargo-contract-build"],
      "provides": ["dylintOutput", "dylintFindings"],
      "requires": ["compilationSuccess"],
      "config": {
        "tool": "cargo-dylint",
        "args": ["dylint", "--all"],
        "timeout": 180000,
        "optional": true
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-dylint",
      "name": "Parse Dylint Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-dylint"],
      "provides": ["parsedDylintFindings"],
      "requires": ["dylintOutput"],
      "config": {
        "function": "parseDylint"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "check-tests-exist",
      "name": "Check for Tests",
      "category": "testing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["validate-structure"],
      "provides": ["testsExist", "testFiles", "e2eTests"],
      "requires": ["sourceDirectories"],
      "config": {
        "function": "checkTestsExist"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-cargo-test",
      "name": "Run Cargo Tests",
      "category": "testing",
      "executor": "tool",
      "estimatedDurationSeconds": 60,
      "dependsOn": ["run-cargo-contract-build", "check-tests-exist"],
      "provides": ["testResults", "testsPassed", "testsFailed"],
      "requires": ["compilationSuccess", "testsExist"],
      "config": {
        "tool": "cargo",
        "command": "test",
        "args": ["--features", "e2e-tests"],
        "timeout": 300000,
        "optional": true
      },
      "progressWeight": 6,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-test-results",
      "name": "Parse Test Results",
      "category": "testing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-cargo-test"],
      "provides": ["parsedTestResults"],
      "requires": ["testResults"],
      "config": {
        "function": "parseTestResults"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-coverage",
      "name": "Run Coverage Analysis",
      "category": "testing",
      "executor": "tool",
      "estimatedDurationSeconds": 90,
      "dependsOn": ["run-cargo-test"],
      "provides": ["coverageReport", "coveragePct"],
      "requires": ["testsPassed"],
      "config": {
        "tool": "cargo-tarpaulin",
        "args": ["--out", "Json"],
        "timeout": 300000,
        "optional": true
      },
      "progressWeight": 6,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-coverage",
      "name": "Parse Coverage Results",
      "category": "testing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-coverage"],
      "provides": ["parsedCoverage", "uncoveredLines"],
      "requires": ["coverageReport"],
      "config": {
        "function": "parseCoverage"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "merge-tool-findings",
      "name": "Merge Tool Findings",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["parse-clippy", "parse-cargo-audit", "parse-dylint"],
      "provides": ["mergedFindings", "findingsByCategory"],
      "requires": [],
      "config": {
        "function": "mergeToolFindings"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "ai-quick-review",
      "name": "AI Quick Review",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["merge-tool-findings", "enumerate-contracts"],
      "provides": ["quickReviewFindings"],
      "requires": ["mergedFindings", "mainContracts"],
      "config": {
        "prompt": "quick-review-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-storage-analysis",
      "name": "AI Storage Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["map-storage-layout"],
      "provides": ["storageFindings", "storageVulnerabilities"],
      "requires": ["storageLayout", "storageItems"],
      "config": {
        "prompt": "analyze-ink-storage",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-reentrancy",
      "name": "AI Reentrancy Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["identify-cross-contract-calls", "merge-tool-findings"],
      "provides": ["reentrancyFindings", "reentrancyVectors"],
      "requires": ["crossContractCalls", "mergedFindings"],
      "config": {
        "prompt": "check-reentrancy-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-access-control",
      "name": "AI Access Control Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 40,
      "dependsOn": ["analyze-messages"],
      "provides": ["accessControlFindings", "privilegedOperations"],
      "requires": ["messages", "publicMessages"],
      "config": {
        "prompt": "analyze-access-control-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-arithmetic",
      "name": "AI Arithmetic Safety Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["analyze-messages"],
      "provides": ["arithmeticFindings", "overflowRisks"],
      "requires": ["messages"],
      "config": {
        "prompt": "check-arithmetic-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-cross-contract",
      "name": "AI Cross-Contract Security",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 40,
      "dependsOn": ["identify-cross-contract-calls"],
      "provides": ["crossContractFindings"],
      "requires": ["crossContractCalls", "delegateCalls"],
      "config": {
        "prompt": "check-cross-contract-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-upgrade-safety",
      "name": "AI Upgrade Safety Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["map-storage-layout", "analyze-contract-structure"],
      "provides": ["upgradeFindings", "storageCollisions"],
      "requires": ["storageLayout", "contractStructure"],
      "config": {
        "prompt": "check-upgrade-safety-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-business-logic",
      "name": "AI Business Logic Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 60,
      "dependsOn": ["analyze-messages", "count-sloc"],
      "provides": ["businessLogicFindings", "logicFlaws"],
      "requires": ["messages", "sloc"],
      "config": {
        "prompt": "analyze-business-logic-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 6,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-validate-findings",
      "name": "AI Finding Validation",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["merge-tool-findings"],
      "provides": ["validatedFindings", "falsePositives"],
      "requires": ["mergedFindings"],
      "config": {
        "prompt": "validate-findings-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "deduplicate",
      "name": "Deduplicate Findings",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["ai-validate-findings", "ai-storage-analysis", "ai-reentrancy", "ai-access-control", "ai-business-logic"],
      "provides": ["deduplicatedFindings"],
      "requires": [],
      "config": {
        "function": "deduplicateFindings"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "calculate-severity",
      "name": "Calculate Final Severity",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["deduplicate"],
      "provides": ["severityRankedFindings"],
      "requires": ["deduplicatedFindings"],
      "config": {
        "function": "calculateSeverity"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "calculate-score",
      "name": "Calculate Audit Score",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["calculate-severity"],
      "provides": ["auditScore", "scoreBreakdown"],
      "requires": ["severityRankedFindings"],
      "config": {
        "function": "calculateScore"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "ai-recommendations",
      "name": "AI Generate Recommendations",
      "category": "reporting",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["calculate-score"],
      "provides": ["recommendations", "remediationPlan"],
      "requires": ["severityRankedFindings", "auditScore"],
      "config": {
        "prompt": "generate-recommendations-ink",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "generate-report",
      "name": "Generate Final Report",
      "category": "reporting",
      "executor": "deterministic",
      "estimatedDurationSeconds": 30,
