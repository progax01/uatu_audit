      "executorConfig": {
        "type": "deterministic",
        "function": "execute-tests-python"
      },
      "estimatedDurationSeconds": 240,
      "timeoutSeconds": 900,
      "dependsOn": ["generate-security-tests-python"],
      "provides": ["testResults", "testExecutionSummary"],
      "requires": ["generatedTests", "testFiles", "projectPath"],
      "category": "testing",
      "aiAssisted": false,
      "progressWeight": 10,
      "required": false,
      "retryCount": 1,
