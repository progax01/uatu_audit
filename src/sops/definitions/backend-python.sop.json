      },
      "estimatedDurationSeconds": 120,
      "timeoutSeconds": 600,
      "dependsOn": ["analyze-routes"],
      "provides": ["aiAuthFindings"],
      "requires": ["srcDir", "routes"],
      "category": "ai-analysis",
      "aiAssisted": true,
      "progressWeight": 10,
      "required": false,
      "retryCount": 1,
      "continueOnFailure": true
    },
    {
      "id": "ai-deserialization-analysis",
      "name": "AI Deserialization Analysis",
      "description": "Analyze pickle/yaml deserialization with AI",
      "executor": "ai",
      "executorConfig": {
        "type": "ai",
        "model": "claude-sonnet-4-5-20250929",
        "promptType": "python-deserialization"
      },
      "estimatedDurationSeconds": 120,
      "timeoutSeconds": 600,
      "dependsOn": ["analyze-serialization-python"],
      "provides": ["aiDeserializationFindings"],
      "requires": ["srcDir", "serializationFindings"],
      "category": "ai-analysis",
      "aiAssisted": true,
      "progressWeight": 10,
      "required": false,
      "retryCount": 1,
      "continueOnFailure": true
    },
    {
      "id": "ai-template-injection",
      "name": "AI Template Injection Analysis",
      "description": "Analyze SSTI vulnerabilities with AI",
      "executor": "ai",
      "executorConfig": {
        "type": "ai",
        "model": "claude-sonnet-4-5-20250929",
        "promptType": "python-template-injection"
      },
      "estimatedDurationSeconds": 120,
      "timeoutSeconds": 600,
      "dependsOn": ["analyze-template-engines"],
