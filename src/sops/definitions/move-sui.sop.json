      "provides": ["finalReport", "reportPath"],
      "requires": ["severityRankedFindings", "auditScore", "recommendations"],
      "config": {
        "function": "generateReport"
      },
      "progressWeight": 3,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    }
  ],

  "requiredTools": [
    {
      "name": "sui",
      "checkCommand": "sui --version",
      "installHint": "cargo install --git https://github.com/MystenLabs/sui.git sui"
    }
  ],

  "optionalTools": []
}
