{
  "id": "base-solidity",
  "name": "Base Solidity Audit SOP",
  "version": "1.0.0",
  "framework": "generic",
  "language": "solidity",
  "description": "Fallback Standard Operating Procedure for auditing Solidity smart contracts when framework is unknown",

  "depths": {
    "quick": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "enumerate-contracts",
        "count-sloc",
        "run-solc-compile",
        "run-slither",
        "parse-slither",
        "merge-tool-findings",
        "ai-quick-review",
        "calculate-score",
        "generate-report"
      ],
      "estimatedDurationMinutes": 8,
      "parallelization": "none"
    },
    "standard": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "enumerate-contracts",
        "analyze-user-flows",
        "count-sloc",
        "check-solc-version",
        "run-solc-compile",
        "parse-compilation",
        "generate-ast",
        "map-inheritance",
        "analyze-imports",
        "detect-interfaces",
        "extract-signatures",
        "identify-external-calls",
        "run-slither",
        "parse-slither",
        "run-semgrep",
        "parse-semgrep",
        "merge-tool-findings",
        "ai-admin-functions",
        "ai-access-control",
        "ai-reentrancy",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 22,
      "parallelization": "low"
    },
    "deep": {
      "enabledSteps": [
        "detect-framework",
        "validate-structure",
        "enumerate-contracts",
        "analyze-user-flows",
        "count-sloc",
        "check-solc-version",
        "run-solc-compile",
        "parse-compilation",
        "generate-ast",
        "map-inheritance",
        "analyze-imports",
        "detect-interfaces",
        "extract-signatures",
        "identify-external-calls",
        "run-slither",
        "parse-slither",
        "run-mythril",
        "parse-mythril",
        "run-semgrep",
        "parse-semgrep",
        "merge-tool-findings",
        "ai-admin-functions",
        "ai-access-control",
        "ai-reentrancy",
        "ai-oracle",
        "ai-business-logic",
        "ai-validate-findings",
        "deduplicate",
        "calculate-severity",
        "generate-tests",
        "publish-to-github",
        "calculate-score",
        "ai-recommendations",
        "generate-report"
      ],
      "estimatedDurationMinutes": 50,
      "parallelization": "high"
    }
  },

  "steps": [
    {
      "id": "detect-framework",
      "name": "Detect Framework",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": [],
      "provides": ["detectedFramework", "detectedLanguage"],
      "requires": [],
      "config": {
        "function": "detectFramework"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "validate-structure",
      "name": "Validate Project Structure",
      "category": "setup",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["detect-framework"],
      "provides": ["projectValid", "sourceDirectories"],
      "requires": ["detectedFramework"],
      "config": {
        "function": "validateStructure"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "enumerate-contracts",
      "name": "Enumerate Contracts",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["validate-structure"],
      "provides": ["contractFiles", "mainContracts", "testContracts", "libraryContracts"],
      "requires": ["sourceDirectories"],
      "config": {
        "function": "enumerateContracts"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "analyze-user-flows",
      "name": "Analyze User Flows",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["userFlows", "entryPoints", "privilegedPaths", "flowAnalysis"],
      "requires": ["contractFiles"],
      "config": {
        "function": "analyzeUserFlows"
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "count-sloc",
      "name": "Count SLOC",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["sloc", "complexity"],
      "requires": ["contractFiles"],
      "config": {
        "function": "countSloc"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "check-solc-version",
      "name": "Check Solidity Version",
      "category": "discovery",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["solcVersions", "versionWarnings"],
      "requires": ["contractFiles"],
      "config": {
        "function": "checkSolcVersion"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-solc-compile",
      "name": "Run Solc Compile",
      "category": "compilation",
      "executor": "tool",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["check-solc-version"],
      "provides": ["compilationSuccess", "compilationArtifacts", "compilationWarnings"],
      "requires": ["solcVersions"],
      "config": {
        "tool": "solc",
        "args": ["--combined-json", "abi,bin,ast", "--allow-paths", "."],
        "timeout": 120000
      },
      "progressWeight": 4,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "parse-compilation",
      "name": "Parse Compilation Results",
      "category": "compilation",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-solc-compile"],
      "provides": ["parsedArtifacts", "contractBytecode", "contractAbi"],
      "requires": ["compilationArtifacts"],
      "config": {
        "function": "parseCompilation"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "generate-ast",
      "name": "Generate AST",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["run-solc-compile"],
      "provides": ["ast", "astNodes"],
      "requires": ["compilationArtifacts"],
      "config": {
        "function": "generateAst"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "map-inheritance",
      "name": "Map Inheritance Tree",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["generate-ast"],
      "provides": ["inheritanceMap", "inheritanceDepth"],
      "requires": ["ast"],
      "config": {
        "function": "mapInheritance"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "analyze-imports",
      "name": "Analyze Import Graph",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["importGraph", "externalDependencies"],
      "requires": ["contractFiles"],
      "config": {
        "function": "analyzeImports"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "detect-interfaces",
      "name": "Detect Implemented Interfaces",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["map-inheritance"],
      "provides": ["implementedInterfaces", "interfaceCompliance"],
      "requires": ["inheritanceMap"],
      "config": {
        "function": "detectInterfaces"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "extract-signatures",
      "name": "Extract Function Signatures",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 15,
      "dependsOn": ["generate-ast"],
      "provides": ["functionSignatures", "functionVisibility", "stateVariables"],
      "requires": ["ast"],
      "config": {
        "function": "extractSignatures"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "identify-external-calls",
      "name": "Identify External Calls",
      "category": "analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 20,
      "dependsOn": ["extract-signatures"],
      "provides": ["externalCalls", "callGraph"],
      "requires": ["functionSignatures"],
      "config": {
        "function": "identifyExternalCalls"
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-slither",
      "name": "Run Slither Analysis",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["slitherOutput", "slitherFindings"],
      "requires": ["contractFiles"],
      "config": {
        "tool": "slither",
        "args": [".", "--json", "-"],
        "timeout": 180000,
        "optional": false
      },
      "progressWeight": 5,
      "required": true,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "parse-slither",
      "name": "Parse Slither Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-slither"],
      "provides": ["parsedSlitherFindings"],
      "requires": ["slitherOutput"],
      "config": {
        "function": "parseSlither"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-mythril",
      "name": "Run Mythril Symbolic Execution",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 120,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["mythrilOutput", "mythrilFindings"],
      "requires": ["contractFiles"],
      "config": {
        "tool": "mythril",
        "args": ["analyze"],
        "timeout": 300000,
        "optional": true
      },
      "progressWeight": 8,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-mythril",
      "name": "Parse Mythril Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-mythril"],
      "provides": ["parsedMythrilFindings"],
      "requires": ["mythrilOutput"],
      "config": {
        "function": "parseMythril"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "run-semgrep",
      "name": "Run Semgrep Patterns",
      "category": "tool-analysis",
      "executor": "tool",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["enumerate-contracts"],
      "provides": ["semgrepOutput", "semgrepFindings"],
      "requires": ["contractFiles"],
      "config": {
        "tool": "semgrep",
        "args": ["--config", "p/smart-contracts", "--json"],
        "timeout": 120000,
        "optional": true
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "parse-semgrep",
      "name": "Parse Semgrep Output",
      "category": "tool-analysis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["run-semgrep"],
      "provides": ["parsedSemgrepFindings"],
      "requires": ["semgrepOutput"],
      "config": {
        "function": "parseSemgrep"
      },
      "progressWeight": 1,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "merge-tool-findings",
      "name": "Merge Tool Findings",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["parse-slither", "parse-mythril", "parse-semgrep"],
      "provides": ["mergedFindings", "findingsByCategory"],
      "requires": [],
      "config": {
        "function": "mergeToolFindings"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "ai-quick-review",
      "name": "AI Quick Review",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["merge-tool-findings", "enumerate-contracts"],
      "provides": ["quickReviewFindings"],
      "requires": ["mergedFindings", "mainContracts"],
      "config": {
        "prompt": "quick-review",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-admin-functions",
      "name": "AI Admin Function Identification",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["identify-external-calls", "detect-interfaces"],
      "provides": ["adminFunctions", "privilegedOperations"],
      "requires": ["externalCalls", "implementedInterfaces"],
      "answerDependencies": ["admin_functions", "upgrade_pattern", "proxy_type", "pausable_functions"],
      "config": {
        "prompt": "identify-admin-functions",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-access-control",
      "name": "AI Access Control Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["ai-admin-functions", "map-inheritance"],
      "provides": ["accessControlFindings", "roleAnalysis"],
      "requires": ["adminFunctions", "inheritanceMap"],
      "answerDependencies": ["admin_functions", "role_based_access", "multisig_required", "timelock_present"],
      "config": {
        "prompt": "analyze-access-control",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-reentrancy",
      "name": "AI Reentrancy Deep Check",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["identify-external-calls", "merge-tool-findings"],
      "provides": ["reentrancyFindings", "reentrancyVectors"],
      "requires": ["externalCalls", "mergedFindings"],
      "answerDependencies": ["reentrancy_guard", "external_calls", "checks_effects_interactions"],
      "config": {
        "prompt": "check-reentrancy",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-oracle",
      "name": "AI Oracle Manipulation Check",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["analyze-imports", "detect-interfaces"],
      "provides": ["oracleFindings", "priceManipulationRisks"],
      "requires": ["externalDependencies", "implementedInterfaces"],
      "answerDependencies": ["defi_oracle_provider", "defi_price_feeds", "defi_twap_used", "oracle_fallback"],
      "config": {
        "prompt": "check-oracle",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-business-logic",
      "name": "AI Business Logic Analysis",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 60,
      "dependsOn": ["extract-signatures", "count-sloc"],
      "provides": ["businessLogicFindings", "logicFlaws"],
      "requires": ["functionSignatures", "sloc"],
      "answerDependencies": ["core_functionality", "expected_behavior", "edge_cases", "known_limitations"],
      "config": {
        "prompt": "analyze-business-logic",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 6,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "ai-validate-findings",
      "name": "AI Finding Validation",
      "category": "ai-analysis",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["merge-tool-findings"],
      "provides": ["validatedFindings", "falsePositives"],
      "requires": ["mergedFindings"],
      "answerDependencies": ["defi_flash_loan_protection", "defi_slippage_protection", "defi_liquidity_checks", "defi_amm_type"],
      "config": {
        "prompt": "validate-findings",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 4,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "deduplicate",
      "name": "Deduplicate Findings",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 10,
      "dependsOn": ["ai-validate-findings", "ai-access-control", "ai-reentrancy", "ai-business-logic"],
      "provides": ["deduplicatedFindings"],
      "requires": [],
      "config": {
        "function": "deduplicateFindings"
      },
      "progressWeight": 2,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "calculate-severity",
      "name": "Calculate Final Severity",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["deduplicate"],
      "provides": ["severityRankedFindings"],
      "requires": ["deduplicatedFindings"],
      "answerDependencies": ["*"],
      "config": {
        "function": "calculateSeverity"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "generate-tests",
      "name": "Generate Test Cases",
      "category": "testing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 120,
      "dependsOn": ["calculate-severity"],
      "provides": ["generatedTests"],
      "requires": ["severityRankedFindings"],
      "config": {
        "function": "generate-tests"
      },
      "progressWeight": 3,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 0
    },
    {
      "id": "publish-to-github",
      "name": "Publish to GitHub",
      "category": "publishing",
      "executor": "deterministic",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["generate-tests"],
      "provides": ["publishedResults"],
      "requires": ["severityRankedFindings"],
      "config": {
        "function": "publish-to-github"
      },
      "progressWeight": 2,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "calculate-score",
      "name": "Calculate Audit Score",
      "category": "synthesis",
      "executor": "deterministic",
      "estimatedDurationSeconds": 5,
      "dependsOn": ["calculate-severity"],
      "provides": ["auditScore", "scoreBreakdown"],
      "requires": ["severityRankedFindings"],
      "config": {
        "function": "calculateScore"
      },
      "progressWeight": 1,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    },
    {
      "id": "ai-recommendations",
      "name": "AI Generate Recommendations",
      "category": "reporting",
      "executor": "ai-prompt",
      "estimatedDurationSeconds": 45,
      "dependsOn": ["calculate-score"],
      "provides": ["recommendations", "remediationPlan"],
      "requires": ["severityRankedFindings", "auditScore"],
      "config": {
        "prompt": "generate-recommendations",
        "maxTokens": 4096,
        "temperature": 0.3
      },
      "progressWeight": 5,
      "required": false,
      "continueOnFailure": true,
      "retryCount": 1
    },
    {
      "id": "generate-report",
      "name": "Generate Final Report",
      "category": "reporting",
      "executor": "deterministic",
      "estimatedDurationSeconds": 30,
      "dependsOn": ["ai-recommendations"],
      "provides": ["finalReport", "reportPath"],
      "requires": ["severityRankedFindings", "auditScore", "recommendations"],
      "config": {
        "function": "generateReport"
      },
      "progressWeight": 3,
      "required": true,
      "continueOnFailure": false,
      "retryCount": 0
    }
  ],

  "requiredTools": [
    {
      "name": "slither",
      "checkCommand": "slither --version",
      "dockerImage": "trailofbits/slither",
      "installHint": "pip install slither-analyzer"
    }
  ],

  "optionalTools": [
    {
      "name": "solc",
      "checkCommand": "solc --version",
      "installHint": "npm install -g solc or use solc-select"
    },
    {
      "name": "mythril",
      "checkCommand": "myth version",
      "dockerImage": "mythril/myth",
      "installHint": "pip install mythril"
    },
    {
      "name": "semgrep",
      "checkCommand": "semgrep --version",
      "installHint": "pip install semgrep"
    }
  ]
}
