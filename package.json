{
  "name": "uatu-audit",
  "version": "0.0.1",
  "description": "Uatu audit automation tooling",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "uatu": "dist/bin/uatu.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "verify": "scripts/verify-production.sh",
    "check-regressions": "scripts/check-regressions.sh",
    "break-glass": "scripts/break-glass.sh",
    "runbook": "scripts/runbook.sh",
    "daemon": "node dist/bin/uatu.js daemon",
    "run:sample": "node dist/bin/uatu.js run --repo https://github.com/Uniswap/v2-core.git --project uniswap-v2 --branch master --test-styles behavioral,stride",
    "report:lint": "scripts/check-regressions.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.36.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.63.1",
    "@types/node-fetch": "^2.6.13",
    "commander": "^14.0.1",
    "dotenv": "^17.2.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.2",
    "lucide-react": "^0.553.0",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.0.0",
    "puppeteer": "^24.22.3",
    "simple-git": "^3.28.0",
    "strip-ansi": "^6.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "zod": "^4.1.11"
  }
}
