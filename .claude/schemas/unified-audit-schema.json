{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Unified Audit Report Schema",
  "version": "2.0.0",
  "description": "Standardized schema for UatuAudit security audit reports across all domains (Web3, Backend, Frontend)",
  "type": "object",
  "required": ["schema_version", "audit_report"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this schema"
    },
    "audit_report": {
      "type": "object",
      "required": ["metadata", "findings", "score"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["target_system", "audit_domain", "auditor_model", "timestamp"],
          "properties": {
            "target_system": {
              "type": "string",
              "description": "Name of the audited system"
            },
            "repository": {
              "type": "string",
              "description": "Git repository URL"
            },
            "commit_hash": {
              "type": "string",
              "description": "Git commit hash of audited code"
            },
            "audit_domain": {
              "type": "string",
              "enum": ["Web3", "Backend", "Frontend", "Multi-Domain"],
              "description": "Primary domain of the audit"
            },
            "audit_depth": {
              "type": "string",
              "enum": ["Quick", "Standard", "Deep"],
              "description": "Depth level of the audit"
            },
            "auditor_model": {
              "type": "string",
              "description": "AI model used for audit (e.g., claude-opus-4-5)"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "ISO-8601 timestamp of audit completion"
            },
            "duration_seconds": {
              "type": "number",
              "minimum": 0,
              "description": "Total audit duration in seconds"
            },
            "milestones_completed": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of completed milestones"
            }
          }
        },
        "executive_summary": {
          "type": "object",
          "properties": {
            "overall_risk": {
              "type": "string",
              "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
              "description": "Overall risk assessment"
            },
            "security_grade": {
              "type": "string",
              "enum": ["A", "B", "C", "D", "F"],
              "description": "Letter grade for security posture"
            },
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Numerical security score (0-100)"
            },
            "critical_count": {
              "type": "number",
              "minimum": 0
            },
            "high_count": {
              "type": "number",
              "minimum": 0
            },
            "total_findings": {
              "type": "number",
              "minimum": 0
            },
            "key_concerns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Top 3-5 security concerns in plain language"
            },
            "business_impact": {
              "type": "string",
              "description": "Business impact summary"
            },
            "recommendation": {
              "type": "string",
              "description": "High-level recommendation (deploy / don't deploy / needs work)"
            }
          }
        },
        "milestone_summary": {
          "type": "object",
          "description": "Summary of each milestone execution",
          "properties": {
            "current_milestone": {
              "type": "string"
            },
            "completion_status": {
              "type": "string",
              "enum": ["Pending", "In Progress", "Complete", "Failed"]
            },
            "milestones_completed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "findings": {
          "type": "object",
          "required": ["summary"],
          "properties": {
            "summary": {
              "type": "object",
              "properties": {
                "total": {
                  "type": "number",
                  "minimum": 0
                },
                "by_severity": {
                  "type": "object",
                  "properties": {
                    "critical": {"type": "number", "minimum": 0},
                    "high": {"type": "number", "minimum": 0},
                    "medium": {"type": "number", "minimum": 0},
                    "low": {"type": "number", "minimum": 0},
                    "info": {"type": "number", "minimum": 0}
                  }
                },
                "by_category": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "by_confidence": {
                  "type": "object",
                  "properties": {
                    "very_high": {"type": "number", "minimum": 0},
                    "high": {"type": "number", "minimum": 0},
                    "medium": {"type": "number", "minimum": 0},
                    "low": {"type": "number", "minimum": 0}
                  }
                }
              }
            },
            "critical": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"}
            },
            "high": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"}
            },
            "medium": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"}
            },
            "low": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"}
            },
            "info": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"}
            },
            "static_analysis": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"},
              "description": "Findings from Milestone 2"
            },
            "logic_analysis": {
              "type": "array",
              "items": {"$ref": "#/definitions/finding"},
              "description": "Findings from Milestone 3"
            }
          }
        },
        "reasoning": {
          "type": "array",
          "description": "Chain-of-Thought reasoning steps",
          "items": {
            "type": "object",
            "required": ["step", "observation", "hypothesis", "validation", "conclusion"],
            "properties": {
              "step": {
                "type": "string",
                "description": "Description of the analysis step"
              },
              "observation": {
                "type": "string",
                "description": "What was observed in the code"
              },
              "hypothesis": {
                "type": "string",
                "description": "Hypothesis about the vulnerability"
              },
              "validation": {
                "oneOf": [
                  {"type": "string"},
                  {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                ],
                "description": "How the hypothesis was validated"
              },
              "conclusion": {
                "type": "string",
                "description": "Final conclusion about the finding"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Confidence score (0.0 - 1.0)"
              },
              "confidence_factors": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Factors contributing to confidence score"
              },
              "related_finding": {
                "type": "string",
                "description": "ID of related finding"
              }
            }
          }
        },
        "tooling_artifacts": {
          "type": "object",
          "description": "Generated test files and scripts",
          "properties": {
            "foundry_tests": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "filename": {"type": "string"},
                  "related_finding": {"type": "string"},
                  "purpose": {"type": "string"},
                  "run_command": {"type": "string"},
                  "content": {"type": "string"}
                }
              }
            },
            "k6_scripts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "filename": {"type": "string"},
                  "related_finding": {"type": "string"},
                  "purpose": {"type": "string"},
                  "run_command": {"type": "string"},
                  "content": {"type": "string"}
                }
              }
            },
            "cypress_tests": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "filename": {"type": "string"},
                  "related_finding": {"type": "string"},
                  "purpose": {"type": "string"},
                  "run_command": {"type": "string"},
                  "content": {"type": "string"}
                }
              }
            },
            "curl_commands": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "finding": {"type": "string"},
                  "vulnerability": {"type": "string"},
                  "command": {"type": "string"},
                  "expected_result": {"type": "string"}
                }
              }
            }
          }
        },
        "score": {
          "type": "object",
          "required": ["value", "grade"],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Numerical score (0-100)"
            },
            "grade": {
              "type": "string",
              "enum": ["A", "B", "C", "D", "F"],
              "description": "Letter grade"
            },
            "calculation": {
              "type": "string",
              "description": "Score calculation formula"
            },
            "breakdown": {
              "type": "object",
              "properties": {
                "critical": {"type": "number"},
                "high": {"type": "number"},
                "medium": {"type": "number"},
                "low": {"type": "number"},
                "info": {"type": "number"}
              }
            },
            "risk_assessment": {
              "type": "object",
              "properties": {
                "overall_risk": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
                },
                "exploitability": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
                },
                "impact": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
                },
                "likelihood": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
                }
              }
            }
          }
        },
        "recommendations": {
          "type": "object",
          "properties": {
            "immediate": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "priority": {"type": "number"},
                  "finding": {"type": "string"},
                  "action": {"type": "string"},
                  "effort": {"type": "string"},
                  "code_example": {"type": "string"},
                  "resources": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            },
            "short_term": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "category": {"type": "string"},
                  "action": {"type": "string"},
                  "affected_functions": {
                    "type": "array",
                    "items": {"type": "string"}
                  },
                  "effort": {"type": "string"}
                }
              }
            },
            "long_term": {
              "type": "array",
              "items": {"type": "string"}
            },
            "security_best_practices": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "conclusion": {
          "type": "object",
          "properties": {
            "summary": {"type": "string"},
            "deployment_readiness": {
              "type": "string",
              "enum": ["READY", "NEEDS WORK", "NOT READY"]
            },
            "required_actions_before_launch": {
              "type": "array",
              "items": {"type": "string"}
            },
            "estimated_remediation_time": {"type": "string"}
          }
        }
      }
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["id", "title", "severity", "confidence", "category", "location", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]+-\\d+$",
          "description": "Unique finding identifier (e.g., WEB3-001, BACKEND-042)"
        },
        "title": {
          "type": "string",
          "description": "Brief, descriptive title"
        },
        "severity": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"],
          "description": "Severity level"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score (0.0 - 1.0)"
        },
        "category": {
          "type": "string",
          "description": "Vulnerability category (e.g., Reentrancy, Access Control, Injection)"
        },
        "location": {
          "type": "object",
          "required": ["file"],
          "properties": {
            "file": {
              "type": "string",
              "description": "File path relative to project root"
            },
            "line": {
              "type": "number",
              "minimum": 1,
              "description": "Line number where issue exists"
            },
            "function": {
              "type": "string",
              "description": "Function or method name"
            },
            "contract": {
              "type": "string",
              "description": "Contract name (Web3 only)"
            },
            "endpoint": {
              "type": "string",
              "description": "API endpoint (Backend only)"
            },
            "component": {
              "type": "string",
              "description": "React/Vue component (Frontend only)"
            }
          }
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the vulnerability"
        },
        "code_snippet": {
          "type": "string",
          "description": "Relevant code snippet"
        },
        "impact": {
          "type": "string",
          "description": "Business/technical impact"
        },
        "exploit_scenario": {
          "type": "string",
          "description": "Step-by-step attack scenario"
        },
        "attack_vector": {
          "type": "string",
          "description": "Detailed attack vector with multi-step flow"
        },
        "economic_impact": {
          "type": "string",
          "description": "Financial impact estimate (for Web3)"
        },
        "affected_contracts": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of affected contracts (Web3)"
        },
        "recommendation": {
          "type": "string",
          "description": "How to fix this issue"
        },
        "references": {
          "type": "array",
          "items": {"type": "string"},
          "description": "External references (SWC, CWE, articles, etc.)"
        },
        "cwe": {
          "type": "string",
          "description": "CWE identifier (e.g., CWE-284)"
        },
        "swc": {
          "type": "string",
          "description": "SWC identifier for smart contracts (e.g., SWC-107)"
        },
        "test_artifact": {
          "type": "string",
          "description": "Associated test file (e.g., Reentrancy.t.sol)"
        },
        "foundry_test": {
          "type": "string",
          "description": "Foundry test filename"
        },
        "k6_script": {
          "type": "string",
          "description": "K6 test filename"
        },
        "cypress_test": {
          "type": "string",
          "description": "Cypress test filename"
        },
        "curl_command": {
          "type": "string",
          "description": "curl command to reproduce (Backend)"
        },
        "reasoning": {
          "type": "object",
          "description": "Chain-of-Thought reasoning for this finding",
          "properties": {
            "step": {"type": "string"},
            "observation": {"type": "string"},
            "hypothesis": {"type": "string"},
            "validation": {
              "oneOf": [
                {"type": "string"},
                {"type": "array", "items": {"type": "string"}}
              ]
            },
            "conclusion": {"type": "string"},
            "confidence": {"type": "number"},
            "confidence_factors": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
