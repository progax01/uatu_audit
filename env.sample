# UatuAudit Configuration
# Copy this file to .env and update with your values

# Daemon Configuration
UATU_PORT=9090
UATU_CONCURRENCY=4
UATU_HOME=/Users/yourusername/.uatu

# GitHub OAuth Configuration (Required for private repos)
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_OAUTH_CALLBACK=http://localhost:9090/auth/github/callback

# Optional: AI Enhancement (for testgen SOP)
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022         # Anthropic model to use (will auto-update to claude-3-5-sonnet-latest)  
UATU_AI_PROVIDER_ORDER=anthropic,cli               # Provider priority: anthropic API first, then CLI fallback
UATU_AI_MAX_FILES=10                              # Max test files to generate per call
UATU_AI_PER_CALL=5                                # Max contracts to process per API call (chunking)
UATU_AI_MIN_FILES=6                               # Minimum files to aim for via oversampling
UATU_AI_REFINE=1                                  # Enable 2-pass AI refinement (0=disable)
UATU_AI_REFINE_MAX_LOG_BYTES=65536                # Max failure log size for refinement (64KB)
UATU_AI_REFINE_MAX_FILES=8                        # Max files to refine per call
UATU_AI_REFINE_TIMEOUT_MS=180000                  # Refinement API timeout (3 minutes)
UATU_AI_TOOL_ORDER=hardhat,foundry,jest           # Order to run AI test passes
# For immediate workaround if API issues: UATU_AI_PROVIDER_ORDER=cli,anthropic
CLAUDE_CLI_PATH=/path/to/claude                    # Custom path to Claude CLI binary
CLAUDE_TIMEOUT_MS=300000                           # Claude CLI timeout (5 minutes default)
CLAUDE_SANDBOX_MODE=true                           # Enable Claude sandbox mode for test generation

# Optional: Security & Performance
UATU_SANDBOX=local                # Options: local, docker
UATU_USE_DOCKER=0                 # 1 to use Docker containers for isolated execution
UATU_EXECUTE_TIMEOUT_MS=900000    # 15 minutes for test execution
UATU_COVERAGE_ENABLED=true
UATU_LOG_LEVEL=info               # Options: error, warn, info, debug

# Optional: Sandbox Configuration (SOP compliance)
UATU_CLEANUP_SANDBOX=false        # Auto-cleanup sandbox after execution
UATU_ENHANCED_SOP=true            # Use enhanced deterministic SOPs

# Optional: Advanced Configuration
UATU_USER=default                 # User namespace for workspace isolation
UATU_WEBHOOK_SECRET=your_webhook_secret_for_github_hmac

# Job Queue Management
UATU_MAX_COMPLETED_JOBS=50        # Keep only N most recent completed jobs (0 = no limit)
UATU_MAX_JOB_AGE_DAYS=7          # Remove jobs older than N days (0 = no limit)

# Node.js & Coverage Optimization
NODE_OPTIONS="--max-old-space-size=4096"
UATU_NODE_HEAP_MB=6144                # Heap memory for coverage (MB) 
UATU_INCLUDE_NETWORK_TESTS=0          # Include network tests (lineaSepolia, etc.) - 0=skip, 1=include

# Development/Testing Overrides (uncomment as needed)
# CLAUDE_TIMEOUT_MS=1000              # Force timeout for testing
UATU_HARDHAT_COVERAGE=1              # Enable Hardhat coverage (set to 0 to stop OOM on Node 23)  
# UATU_LOG_LEVEL=debug                # Verbose logging
# UATU_INCLUDE_NETWORK_TESTS=1        # Include network-coupled tests
# UATU_AI_PROVIDER_ORDER=none         # Disable AI entirely
UATU_RUN_AI_TESTS_ONLY=1             # Run only AI tests (skip user tests) - 1=AI only, 0=both
UATU_CLEANUP_AI_TESTS=0              # Clean up AI tests from sandbox after execution
