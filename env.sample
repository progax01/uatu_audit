# UatuAudit Configuration
# Copy this file to .env and update with your values

# Daemon Configuration
UATU_PORT=9090
UATU_CONCURRENCY=4
UATU_HOME=/Users/yourusername/.uatu

# GitHub OAuth Configuration (Required for private repos)
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_OAUTH_CALLBACK=http://localhost:9090/auth/github/callback

# Optional: AI Enhancement (for testgen SOP)
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_CLI_PATH=/path/to/claude                    # Custom path to Claude CLI binary
CLAUDE_TIMEOUT_MS=300000                           # Claude CLI timeout (5 minutes default)
CLAUDE_SANDBOX_MODE=true                           # Enable Claude sandbox mode for test generation

# Optional: Security & Performance
UATU_SANDBOX=local                # Options: local, docker
UATU_EXECUTE_TIMEOUT_MS=900000    # 15 minutes for test execution
UATU_COVERAGE_ENABLED=true
UATU_LOG_LEVEL=info               # Options: error, warn, info, debug

# Optional: Sandbox Configuration (SOP compliance)
UATU_CLEANUP_SANDBOX=false        # Auto-cleanup sandbox after execution
UATU_ENHANCED_SOP=true            # Use enhanced deterministic SOPs

# Optional: Advanced Configuration
UATU_USER=default                 # User namespace for workspace isolation
UATU_WEBHOOK_SECRET=your_webhook_secret_for_github_hmac

# Node.js Optimization
NODE_OPTIONS="--max-old-space-size=4096"

# Development/Testing Overrides (uncomment as needed)
# CLAUDE_TIMEOUT_MS=1000              # Force timeout for testing
# UATU_HARDHAT_COVERAGE=0             # Disable coverage for faster testing  
# UATU_LOG_LEVEL=debug                # Verbose logging
