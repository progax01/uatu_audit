# =============================================
# UatuAudit Environment Configuration
# =============================================

# Daemon Configuration
UATU_PORT=9090
UATU_CONCURRENCY=2
UATU_HOME=/Users/yourusername/.uatu

# GitHub OAuth (Required for private repos)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_OAUTH_CALLBACK=http://localhost:9090/auth/github/callback

# Optional: AI Enhancement
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Detailed Audit Mode (parallel multi-session)
ENABLE_DETAILED_AUDIT=false

# Optional: Sandbox Configuration
UATU_SANDBOX=docker                # Enable Docker sandbox (default: local)
UATU_EXECUTE_TIMEOUT_MS=900000    # 15 minutes

# =============================================
# Block Explorer API Keys (for Scan Deployed Contract)
# =============================================

# Ethereum
ETHERSCAN_API_KEY=your_etherscan_key_here

# Polygon
POLYGONSCAN_API_KEY=your_polygonscan_key_here

# BSC
BSCSCAN_API_KEY=your_bscscan_key_here

# Arbitrum
ARBISCAN_API_KEY=your_arbiscan_key_here

# Base
BASESCAN_API_KEY=your_basescan_key_here

# Optimism
OPTIMISM_API_KEY=your_optimism_key_here

# Sourcify (open source, no key required but rate limited)
SOURCIFY_ENABLED=true
